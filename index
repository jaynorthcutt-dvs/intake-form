<script>
  function toggleSection(id, show) {
    var el = document.getElementById(id);
    if (!el) return;
    if (show) {
      el.classList.remove('dvs-hidden');
      el.classList.add('dvs-visible');
    } else {
      el.classList.remove('dvs-visible');
      el.classList.add('dvs-hidden');
    }
  }

  function handleApplyingChange() {
    const adults = parseInt(document.getElementById('adults-applying-select').value) || 0;
    const deps = parseInt(document.getElementById('deps-applying-select').value) || 0;

    // Spouse section
    toggleSection('spouse-section', adults > 1);
    syncAdultCards(adults > 1 ? 1 : 0);

    // Applying dependents section
    toggleSection('applying-deps-section', deps > 0);
    syncApplyingDepCards(deps);

    // Trigger household check too
    handleHouseholdChange();
  }

  function getApplyingMembersForIncome() {
    var members = [];

    // 1. Primary applicant — always included
    var pfn = document.querySelector('[name="first_name"]');
    var pln = document.querySelector('[name="last_name"]');
    members.push({
      name: ((pfn&&pfn.value?pfn.value:'') + ' ' + (pln&&pln.value?pln.value:'')).trim() || 'Primary Applicant',
      key: 'primary'
    });

    // 2. Spouse — include if spouse section is visible (regardless of name filled)
    var spouseSec = document.getElementById('spouse-section');
    var spouseVisible = spouseSec && !spouseSec.classList.contains('dvs-hidden');
    // Also check private app spouse select
    var privateSpouse = document.getElementById('private-spouse-select');
    if (privateSpouse && privateSpouse.value === 'yes') spouseVisible = true;
    if (spouseVisible) {
      var sf = document.querySelector('[name="adult1_first"]');
      var sl = document.querySelector('[name="adult1_last"]');
      var spouseName = sf && sf.value ? (sf.value + ' ' + (sl?sl.value:'')).trim() : 'Spouse';
      members.push({ name: spouseName, key: 'hh1' });
    }

    // 3. Applying dependents — include if dep cards exist
    for (var d = 1; d <= 5; d++) {
      var df = document.querySelector('[name="dep'+d+'_first"]');
      var dl = document.querySelector('[name="dep'+d+'_last"]');
      if (df) {
        var depName = df.value ? (df.value+' '+(dl?dl.value:'')).trim() : 'Dependent '+d;
        members.push({ name: depName, key: 'hh'+members.length });
      }
    }

    // 4. Non-applying members
    for (var n = 1; n <= 9; n++) {
      var nf = document.querySelector('[name="na_dep'+n+'_first"]');
      var nl = document.querySelector('[name="na_dep'+n+'_last"]');
      if (nf) {
        var naName = nf.value ? (nf.value+' '+(nl?nl.value:'')).trim() : 'Household Member';
        members.push({ name: naName, key: 'hh'+members.length });
      }
    }

    return members;
  }

  function rebuildIncomeCards() {
    var container = document.getElementById('income-cards-container');
    if (!container) return;
    var members = getApplyingMembersForIncome();

    container.innerHTML = '';
    members.forEach(function(member, idx) {
      var ip  = idx === 0;
      var en  = ip ? 'employment_status'  : member.key + '_employment';
      var er  = ip ? 'employer-row'       : member.key + '-emp-row';
      var wr  = ip ? 'selfemployed-row'   : member.key + '-work-row';
      var empNm  = ip ? 'employer'        : member.key + '_employer';
      var workNm = ip ? 'type_of_work'    : member.key + '_type_of_work';
      var incNm  = ip ? 'annual_income'   : member.key + '_annual_income';
      var req = ip ? ' required' : '';
      var rs  = ip ? ' <span class="req">*</span>' : '';
      var erSafe = encodeURIComponent(er);
      var wrSafe = encodeURIComponent(wr);

      var div = document.createElement('div');
      div.className = 'member-card';
      div.style.cssText = 'margin-bottom:1rem; padding:1rem; background:#132030; border:0.5px solid #2a3f58; border-radius:8px;';
      div.innerHTML =
        '<div class="dep-section-header" style="margin-bottom:12px;color:#a8d4ff;">' + member.name + '</div>' +
        '<div class="field-row">' +
          '<div class="field"><label>Employment status' + rs + '</label>' +
            '<select name="' + en + '"' + req +
              ' onchange="handleIncomeEmp(this,decodeURIComponent(\'' + erSafe + '\'),decodeURIComponent(\'' + wrSafe + '\'))"' +
              ' onclick="handleIncomeEmp(this,decodeURIComponent(\'' + erSafe + '\'),decodeURIComponent(\'' + wrSafe + '\'))">' +
              '<option value="">Select</option>' +
              '<option>Employed (W-2)</option><option>Self-employed / 1099</option>' +
              '<option>Unemployed</option><option>Retired</option>' +
              '<option>Student</option><option>No income</option><option>Other</option>' +
            '</select></div>' +
          '<div class="field"><label>Annual income' + rs + '</label>' +
            '<input type="number" name="' + incNm + '"' + req + ' placeholder="e.g. 42000" min="0">' +
          '</div>' +
        '</div>' +
        '<div class="field-row full" id="' + er + '" style="display:none;">' +
          '<div class="field"><label>Employer name</label>' +
            '<input type="text" name="' + empNm + '" placeholder="Employer name"></div>' +
        '</div>' +
        '<div class="field-row full" id="' + wr + '" style="display:none;">' +
          '<div class="field"><label>Type of work</label>' +
            '<input type="text" name="' + workNm + '" placeholder="e.g. Trucking, Contractor..."></div>' +
        '</div>';
      container.appendChild(div);
    });
  }

  function handleIncomeEmp(sel, empRowId, workRowId) {
    var er=document.getElementById(empRowId), wr=document.getElementById(workRowId);
    if(er) er.style.display=sel.value==='Employed (W-2)'?'':'none';
    if(wr) wr.style.display=sel.value==='Self-employed / 1099'?'':'none';
  }

  function getHouseholdMemberName(num) { return 'Member ' + num; }
  function syncHouseholdIncomeCards() { rebuildIncomeCards(); }
  function handleHHEmployment(sel, num) {
    var er = document.getElementById('hh' + num + '-emp-row');
    var wr = document.getElementById('hh' + num + '-work-row');
    if (er) er.style.display = sel.value === 'Employed (W-2)' ? '' : 'none';
    if (wr) wr.style.display = sel.value === 'Self-employed / 1099' ? '' : 'none';
  }
  function refreshAllIncomeNames() { rebuildIncomeCards(); }

  function addHouseholdIncomeCard(num) {
    const container = document.getElementById('household-income-container');
    const memberName = getHouseholdMemberName(num);
    const div = document.createElement('div');
    div.className = 'hh-income-card';
    div.style.cssText = 'margin-top: 1rem; border-top: 0.5px solid #2a3347; padding-top: 1rem;';
    div.innerHTML = `
      <div class="dep-section-header" style="margin-bottom: 12px; display:flex; align-items:center; gap:8px;">
        <span class="income-member-name">${memberName}</span>
      </div>
      <div class="field-row full">
        <div class="field">
          <label>Employment status</label>
          <select name="hh${num}_employment" onchange="handleHHEmployment(this, ${num})">
            <option value="">Select</option>
            <option>Employed (W-2)</option>
            <option>Self-employed / 1099</option>
            <option>Unemployed</option>
            <option>Retired</option>
            <option>Student</option>
            <option>No income</option>
            <option>Other</option>
          </select>
        </div>
      </div>
      <div class="field-row full" id="hh${num}-employer-row" style="display:none;">
        <div class="field">
          <label>Employer name</label>
          <input type="text" name="hh${num}_employer" placeholder="Employer name">
        </div>
      </div>
      <div class="field-row full" id="hh${num}-work-row" style="display:none;">
        <div class="field">
          <label>Type of work</label>
          <input type="text" name="hh${num}_type_of_work" placeholder="Describe your primary occupation or field of work">
        </div>
      </div>
      <div class="field-row full">
        <div class="field">
          <label>Estimated annual income</label>
          <input type="number" name="hh${num}_annual_income" placeholder="e.g. 0" min="0">
        </div>
      </div>
    `;
    container.appendChild(div);
  }



  function handleHouseholdChange() {
    const adults = parseInt(document.getElementById('adults-applying-select').value) || 0;
    const deps = parseInt(document.getElementById('deps-applying-select').value) || 0;
    const household = parseInt(document.getElementById('household-size-select').value) || 0;

    const nonApplying = Math.max(0, household - adults - deps);
    const showNonApplying = nonApplying > 0 && household > 0 && adults > 0;

    toggleSection('non-applying-section', showNonApplying);
    syncNonApplyingDepCards(nonApplying);
    syncHouseholdIncomeCards();
    rebuildIncomeCards();
  }

  function syncAdultCards(needed) {
    const container = document.getElementById('adults-container');
    const current = container.querySelectorAll('.adult-card').length;
    if (needed > current) {
      for (let i = current + 1; i <= needed; i++) addAdultCard(i);
    } else if (needed < current) {
      const cards = container.querySelectorAll('.adult-card');
      for (let i = cards.length; i > needed; i--) cards[i - 1].remove();
    }
  }

  function addAdultCard(num) {
    const container = document.getElementById('adults-container');
    const div = document.createElement('div');
    div.className = 'adult-card member-card';
    div.innerHTML = `
      <div class="dep-section-header">Spouse</div>
      <div class="field-row thirds">
        <div class="field"><label>First name <span class="req">*</span></label><input type="text" name="adult${num}_first" required placeholder="First"></div>
        <div class="field"><label>Middle name</label><input type="text" name="adult${num}_middle" placeholder="Middle"></div>
        <div class="field"><label>Last name <span class="req">*</span></label><input type="text" name="adult${num}_last" required placeholder="Last"></div>
      </div>
      <div class="field-row">
        <div class="field"><label>Date of birth <span class="req">*</span></label><input type="date" name="adult${num}_dob" required></div>
        <div class="field"><label>Gender <span class="req">*</span></label>
          <select name="adult${num}_gender" required>
            <option value="">Select</option>
            <option>Male</option><option>Female</option><option>Other</option>
          </select>
        </div>
      </div>
      <div class="field-row full">
        <div class="field">
          <label>SSN <span class="req">*</span></label>
          <input type="text" name="adult${num}_ssn" id="adult${num}-ssn-input" required placeholder="XXX-XX-XXXX" maxlength="11">
        </div>
        <div class="field"><label>Immigration / citizenship status <span class="req">*</span></label>
          <select name="adult${num}_citizenship">
            <option value="">Select</option>
            <option>U.S. Citizen</option><option>U.S. National</option><option>Lawfully Present Non-Citizen</option>
          </select>
        </div>
      </div>
      <div class="field-row">
        <div class="field"><label>Phone</label><input type="tel" name="adult${num}_phone" placeholder="(000) 000-0000"></div>
        <div class="field"><label>Email</label><input type="email" name="adult${num}_email" placeholder="email@example.com"></div>
      </div>
      <div class="field-row">
        <div class="field"><label>Relationship to primary applicant <span class="req">*</span></label>
          <select name="adult${num}_rel">
            <option value="">Select</option>
            <option>Spouse</option>
            <option>Domestic Partner</option>
            <option>Child</option>
            <option>Stepchild</option>
            <option>Parent</option>
            <option>Stepparent</option>
            <option>Sibling</option>
            <option>Grandchild</option>
            <option>Grandparent</option>
            <option>Other</option>
          </select>
        </div>
        <div class="field"><label>Employment status</label>
          <select name="adult${num}_employment">
            <option value="">Select</option>
            <option>Employed (W-2)</option><option>Self-employed / 1099</option><option>Unemployed</option><option>Retired</option><option>Student</option><option>Other</option>
          </select>
        </div>
      </div>
    `;
    container.appendChild(div);
  }

  function syncApplyingDepCards(needed) {
    const container = document.getElementById('members-container');
    const current = container.querySelectorAll('.member-card').length;
    if (needed > current) {
      for (let i = current + 1; i <= needed; i++) addDepCard(i, 'members-container', true);
    } else if (needed < current) {
      const cards = container.querySelectorAll('.member-card');
      for (let i = cards.length; i > needed; i--) cards[i - 1].remove();
    }
  }

  function syncNonApplyingDepCards(needed) {
    const container = document.getElementById('na-deps-container');
    const current = container.querySelectorAll('.member-card').length;
    if (needed > current) {
      for (let i = current + 1; i <= needed; i++) addDepCard(i, 'na-deps-container', false);
    } else if (needed < current) {
      const cards = container.querySelectorAll('.member-card');
      for (let i = cards.length; i > needed; i--) cards[i - 1].remove();
    }
  }

  function addDepCard(num, containerId, applying) {
    const container = document.getElementById(containerId);
    const prefix = applying ? 'dep' : 'na_dep';
    const label = applying ? 'Dependent' : 'Household Member';
    const div = document.createElement('div');
    div.className = 'member-card';
    div.innerHTML = `
      <div class="dep-section-header">${label} ${num}</div>
      <div class="field-row thirds">
        <div class="field"><label>First name <span class="req">*</span></label><input type="text" name="${prefix}${num}_first" required placeholder="First"></div>
