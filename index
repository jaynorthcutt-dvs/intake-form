  let activePayTab = null;

  const achFields = ['bank_name','account_type','routing_number','account_number','bank_account_name'];
  const cardFields = ['card_type','card_name','card_number','card_expiry','card_cvv','card_zip'];

  function setPaymentRequired(fields, required) {
    fields.forEach(name => {
      const el = document.querySelector('[name="' + name + '"]');
      if (el) el.required = required;
    });
  }

  function togglePayTab(tab) {
    if (activePayTab === tab) {
      // Deselect — remove required from all
      document.getElementById('tab-' + tab).classList.remove('active');
      document.getElementById('panel-' + tab).classList.remove('active');
      setPaymentRequired(achFields, false);
      setPaymentRequired(cardFields, false);
      activePayTab = null;
    } else {
      // Deselect previous
      if (activePayTab) {
        document.getElementById('tab-' + activePayTab).classList.remove('active');
        document.getElementById('panel-' + activePayTab).classList.remove('active');
        setPaymentRequired(activePayTab === 'ach' ? achFields : cardFields, false);
      }
      document.getElementById('tab-' + tab).classList.add('active');
      document.getElementById('panel-' + tab).classList.add('active');
      // Make selected tab fields required
      setPaymentRequired(tab === 'ach' ? achFields : cardFields, true);
      activePayTab = tab;
