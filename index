  function filterCarriersByCategory(category, context) {
    var appType = document.body.dataset.appType === 'private' ? 'private' : 'aca';
    var ctx = context || appType;
    var map = CARRIER_CATEGORY_MAP[ctx] || CARRIER_CATEGORY_MAP['aca'];

    var allCarriers = ctx === 'private' ? PRIVATE_CARRIERS : ACA_CARRIERS;
    var carriers = category === 'All' ? allCarriers : (map[category] || []);

    // Deduplicate and sort
    var seen = {};
    var unique = [];
    carriers.forEach(function(c) { if (!seen[c] && c !== 'Other') { seen[c] = true; unique.push(c); } });
    unique.sort();
    unique.push('Other');

    var sel = document.getElementById('carrier-select');
    if (!sel) return;
    var currentVal = sel.value;
    sel.innerHTML = '<option value="">Select carrier</option>';
    unique.forEach(function(c) {
      var opt = document.createElement('option');
      opt.value = c; opt.textContent = c;
      if (c === currentVal) opt.selected = true;
      sel.appendChild(opt);
    });
  }

  function filterAddCarriersByCategory(category, num) {
    var carriers = category === 'All' ? ACA_ADDITIONAL_CARRIERS : (ADDITIONAL_CATEGORY_MAP[category] || []);

    var seen = {};
    var unique = [];
    carriers.forEach(function(c) { if (!seen[c] && c !== 'Other') { seen[c] = true; unique.push(c); } });
    unique.sort();
    unique.push('Other');

    var sel = document.getElementById('add' + num + '-carrier');
    if (!sel) return;
    var currentVal = sel.value;
    sel.innerHTML = '<option value="">Select carrier</option>';
    unique.forEach(function(c) {
      var opt = document.createElement('option');
      opt.value = c; opt.textContent = c;
      if (c === currentVal) opt.selected = true;
      sel.appendChild(opt);
    });
  }

