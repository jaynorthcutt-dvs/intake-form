    // Init form submit
    initFormSubmit();

    // Polling fallback for mobile browsers that miss change events
    var lastAdults = '', lastDeps = '', lastHousehold = '';
    setInterval(function() {
      var adultsVal = document.getElementById('adults-applying-select') ? document.getElementById('adults-applying-select').value : '';
      var depsVal = document.getElementById('deps-applying-select') ? document.getElementById('deps-applying-select').value : '';
      var hhVal = document.getElementById('household-size-select') ? document.getElementById('household-size-select').value : '';

      if (adultsVal !== lastAdults || depsVal !== lastDeps) {
        lastAdults = adultsVal;
        lastDeps = depsVal;
