      if (citEl && citEl.closest('.field-row') && !citEl.value) validationErrors.push('Citizenship status');
    }

    // Plan required (not self-service)
    if (landingChoice !== 'self') {
      ['carrier','monthly_premium','effective_date','draft_date'].forEach(function(n) {
        var el = document.querySelector('[name="' + n + '"]');
        if (el && !el.value) validationErrors.push(n.replace(/_/g,' '));
      });
    }

    if (validationErrors.length > 0) {
      alert('Please complete: ' + validationErrors.join(', '));
      return;
    }

    // Validate payment method selected
    if (!activePayTab) {
      document.getElementById('pay-error').style.display = 'block';
      document.getElementById('pay-error').scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    // Set correct partner fields based on role before submitting
    if (landingChoice === 'broker') {
      payload['partner_name']    = 'Diversity Health Solutions LLC';
      payload['partner_contact'] = 'Jay Northcutt';
      payload['partner_email']   = 'jaynorthcutt@dvs-health.com';
