<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DVS Health – Health Insurance Application</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Andika:ital,wght@0,400;0,700;1,400;1,700&display=swap');
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Andika', sans-serif;
      background: #091528;
      color: #edf4ff;
      min-height: 100vh;
      padding: 0 0 5rem;
      font-size: 16px;
    }

    .wrap { max-width: 740px; margin: 0 auto; padding: 0 1rem; }

    /* ── Header ── */
    .header {
      background: #0b1a2c; border-bottom: 1.5px solid #2c4a68;
      padding: 0 1.5rem; height: 54px;
      display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 100; margin-bottom: 2rem;
    }
    .header-logo { display: flex; align-items: center; gap: 10px; }
    .header-logo img { height: 30px; width: 30px; border-radius: 7px; object-fit: contain; }
    .header-logo span { font-size: 15px; font-weight: 700; color: #edf4ff; }

    /* ── Landing ── */
    #landing-screen, #apptype-screen {
      display: flex; flex-direction: column; align-items: center;
      justify-content: center; min-height: 80vh; text-align: center; padding: 2rem 1rem;
    }
    .lp-logo {
      width: 68px; height: 68px; border-radius: 16px;
      background: #0f1e32; border: 1.5px solid #2c4a68;
      margin: 0 auto 1.5rem; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
    }
    .lp-logo img { width: 100%; height: 100%; object-fit: contain; }
    .lp-brand { font-size: 11px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: #b8d0e8; margin-bottom: .4rem; }
    .lp-title { font-family: 'Andika', sans-serif; font-family: 'Andika', sans-serif; font-size: clamp(28px,5vw,40px); font-weight: 700; color: #edf4ff; line-height: 1.2; margin-bottom: .6rem; }
    .lp-sub { font-size: 14px; color: #aec8de; margin-bottom: 2.25rem; }

    .lp-options { display: flex; flex-direction: column; gap: 10px; width: 100%; max-width: 420px; }
    .lp-option {
      width: 100%; padding: 20px 22px; border-radius: 14px;
      border: 1.5px solid #2c4a68; background: #0f1e32;
      color: #edf4ff; font-family: 'Andika', sans-serif;
      cursor: pointer; transition: all .18s;
      display: flex; align-items: flex-start; gap: 18px;
      text-align: left; margin-bottom: 12px;
    }
    .lp-option:hover {
      border-color: #3b82f6; background: #132438;
    }
    .lp-option.selected {
      border-color: #3b82f6; background: #132438;
      box-shadow: 0 0 0 3px rgba(59,130,246,.15);
    }
    .lp-option-icon { font-size: 20px; width: 34px; text-align: center; }
    .lp-option-label { font-weight: 600; font-size: 14px; }
    .lp-option-desc { font-size: 12px; color: #aec8de; margin-top: 1px; }

    .lp-proceed-btn {
      margin-top: 1.25rem; width: 100%; max-width: 420px; padding: 16px;
      border-radius: 12px; background: #3b82f6; color: #fff; border: none;
      font-family: 'Andika', sans-serif; font-size: 15px; font-weight: 600;
      cursor: pointer; transition: all .18s;
    }
    .lp-proceed-btn:hover { background: #2563eb; }
    .lp-proceed-btn:disabled { opacity: .4; cursor: not-allowed; }
    .lp-proceed-btn:not(.ready) { opacity: .4; cursor: not-allowed; pointer-events: none; }
    .lp-proceed-btn.ready { opacity: 1; pointer-events: auto; }

    .lp-input-wrap { width: 100%; max-width: 420px; margin-bottom: 1rem; display: none; }
    .broker-password-input { width: 100%; max-width: 420px; margin-bottom: 1rem; display: none; }

    /* ── App type ── */
    .apptype-options { display: flex; gap: 12px; width: 100%; max-width: 500px; }
    .at-option {
      flex: 1; padding: 18px 14px; border-radius: 12px;
      border: 1.5px solid #2c4a68; background: #0f1e32;
      cursor: pointer; transition: all .18s; text-align: center;
    }
    .at-option:hover { border-color: #3b82f6; background: #112030; }
    .at-option.selected { border-color: #3b82f6; background: #112030; box-shadow: 0 0 0 4px rgba(59,130,246,0.30); }
    .at-option-icon { font-size: 26px; margin-bottom: 8px; }
    .at-option-label { font-weight: 600; font-size: 14px; color: #edf4ff; }
    .at-option-desc { font-size: 12px; color: #aec8de; margin-top: 3px; }

    /* ── Back btn ── */
    .back-btn {
      display: inline-flex; align-items: center; gap: 6px;
      background: transparent; border: 1.5px solid #2c4a68;
      border-radius: 8px; padding: 8px 14px; color: #aec8de;
      font-family: 'Andika', sans-serif; font-size: 12px; font-weight: 500;
      cursor: pointer; margin-bottom: 1.5rem; transition: all .15s;
    }
    .back-btn:hover { border-color: #2a4060; color: #edf4ff; }

    /* ── Sections ── */
    .section {
      background: #0f1e32; border: 1.5px solid #2c4a68;
      border-radius: 12px; padding: 1.5rem; margin-bottom: 1.25rem;
    }
    .section-title {
      font-family: 'Andika', sans-serif;
      font-size: 11px; font-weight: 700; letter-spacing: .04em;
      text-transform: uppercase; color: #aec8de;
      margin-bottom: 1.25rem; padding-bottom: .6rem;
      border-bottom: 1.5px solid #2c4a68;
    }

    /* ── Fields ── */
    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
    .field-row.full { grid-template-columns: 1fr; }
    .field-row.thirds { grid-template-columns: 1fr 1fr 1fr; }
    .field { display: flex; flex-direction: column; gap: 5px; }
    .field label { font-size: 13px; font-weight: 700; color: #b0ccdf; text-transform: uppercase; letter-spacing: .06em; }

    /* ── Inputs ── */
    input[type=text], input[type=date], input[type=email],
    input[type=tel], input[type=number], select, textarea {
      font-family: 'Andika', sans-serif; font-size: 16px;
      padding: 12px 14px; border: 1.5px solid #2c4a68;
      border-radius: 8px; background: #091528; color: #edf4ff;
      width: 100%; transition: border-color .15s; outline: none;
      display: block !important; visibility: visible !important; opacity: 1 !important;
    }
    input::placeholder, textarea::placeholder { color: #7a9ab8; }
    input:focus, select:focus, textarea:focus {
      border-color: #3b82f6; box-shadow: 0 0 0 4px rgba(59,130,246,0.30);
    }
    select option { background: #0f1e32; color: #edf4ff; }
    textarea { resize: vertical; min-height: 78px; }

    /* ── Radio / checkbox ── */
    .radio-group { display: flex; flex-wrap: wrap; gap: 8px; }
    .radio-opt {
      display: flex; align-items: center; gap: 7px;
      padding: 10px 14px; border: 1.5px solid #2c4a68;
      border-radius: 8px; cursor: pointer; transition: all .15s;
      font-size: 13px; color: #aec8dc; background: #091528;
    }
    .radio-opt:hover { border-color: #2a4060; color: #edf4ff; }
    .radio-opt input { width: auto !important; display: inline !important; }

    /* ── Coverage summary ── */
    .coverage-summary {
      background: #112030; border: 1.5px solid #2c4a68;
      border-radius: 8px; padding: .9rem 1.1rem;
      margin-bottom: 1.1rem; display: flex; gap: 1.5rem; flex-wrap: wrap;
    }
    .cov-stat .num { font-family: 'Andika', sans-serif; font-size: 24px; font-weight: 700; color: #3b82f6; line-height: 1; }
    .cov-stat .lbl { font-size: 11px; color: #aec8de; margin-top: 2px; }

    /* ── Member cards ── */
    .member-card { border: 1.5px solid #2c4a68; border-radius: 10px; padding: 1.1rem; margin-bottom: .9rem; background: #091528; }
    .member-card-title { font-family: 'Andika', sans-serif; font-size: 12px; font-weight: 700; color: #b0cce0; text-transform: uppercase; letter-spacing: .06em; margin-bottom: .9rem; }

    /* ── Plan ── */
    .plan-highlight { background: #112030; border: 1.5px solid #2c4a68; border-radius: 12px; padding: 1.5rem; margin-bottom: 1.25rem; }
    .pay-tab {
      padding: 8px 16px; border-radius: 8px; border: 1.5px solid #2c4a68;
      background: #091528; color: #aec8dc; font-size: 13px; font-weight: 500;
      cursor: pointer; transition: all .15s;
    }
    .pay-tab.active { border-color: #3b82f6; color: #3b82f6; background: rgba(59,130,246,.08); }

    .carrier-filter-row { display: flex; gap: 10px; align-items: center; margin-bottom: .9rem; }
    .carrier-filter-select {
      font-family: 'Andika', sans-serif; font-size: 12px; padding: 6px 10px;
      border: 1.5px solid #2c4a68; border-radius: 7px;
      background: #091528; color: #aec8dc; cursor: pointer; outline: none;
    }

    /* ── Attestation ── */
    .attest-item {
      display: flex; gap: 10px; align-items: flex-start; padding: 12px;
      border: 1.5px solid #2c4a68; border-radius: 8px; margin-bottom: 8px; background: #091528;
    }
    .attest-item input[type=radio], .attest-item input[type=checkbox] { width: auto !important; margin-top: 2px; flex-shrink: 0; }

    /* ── Signature ── */
    #sig-canvas { border: 1.5px solid #2c4a68; border-radius: 8px; background: #112030; display: block; cursor: crosshair; width: 100%; touch-action: none; }
    .sig-actions { display: flex; gap: 8px; margin-top: 8px; }
    .sig-btn { padding: 6px 12px; border-radius: 7px; border: 1.5px solid #2c4a68; background: transparent; color: #aec8de; font-size: 12px; font-weight: 500; cursor: pointer; }
    .sig-btn:hover { border-color: #2a4060; color: #edf4ff; }

    /* ── Submit ── */
    .submit-btn {
      width: 100%; padding: 17px; border-radius: 12px;
      background: #3b82f6; color: #fff; border: none;
      font-family: 'Andika', sans-serif; font-size: 17px; font-weight: 600;
      cursor: pointer; transition: all .2s;
    }
    .submit-btn:hover { background: #2563eb; }
    .submit-btn:disabled { opacity: .5; cursor: not-allowed; }

    .req { color: #f87171; font-size: 10px; margin-left: 2px; }
    .error-msg { font-size: 12px; color: #f87171; margin-top: 5px; display: none; }
    #pay-error { font-size: 12px; color: #f87171; margin-top: 7px; display: none; text-align: center; }
    .tcpa-label { display: flex; gap: 10px; align-items: flex-start; font-size: 13px; color: #aec8de; line-height: 1.5; cursor: pointer; }
    .tcpa-label input { width: auto !important; margin-top: 3px; flex-shrink: 0; }

    #success-screen { display: none; text-align: center; padding: 3rem 1rem; }
    .success-icon { font-size: 44px; margin-bottom: 1rem; }
    .success-title { font-family: 'Andika', sans-serif; font-family: 'Andika', sans-serif; font-size: 28px; font-weight: 700; color: #34d399; margin-bottom: .6rem; }
    .success-sub { font-size: 14px; color: #aec8de; }

    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: #091528; }
    ::-webkit-scrollbar-thumb { background: #1e3352; border-radius: 3px; }

    @media (max-width: 600px) {
      .field-row, .field-row.thirds { grid-template-columns: 1fr; }
      .apptype-options { flex-direction: column; }
      .wrap { padding: 0 .75rem; }
    }
  
    .lp-option-icon-wrap {
      width: 48px; height: 48px; border-radius: 12px;
      background: rgba(59,130,246,.1); border: 1px solid rgba(59,130,246,.2);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; color: #60a5fa; transition: all .18s;
    }
    .lp-option.selected .lp-option-icon-wrap,
    .lp-option:hover .lp-option-icon-wrap {
      background: rgba(59,130,246,.2); border-color: rgba(59,130,246,.4);
    }
    .lp-option-body { flex: 1; }
    .lp-opt-title {
      font-family: 'Andika', sans-serif;
      font-size: 17px; font-weight: 600; color: #edf4ff; margin-bottom: 5px;
    }
    .lp-opt-desc {
      font-size: 13px; color: #8aaac8; line-height: 1.5;
    }
    .lp-proceed-btn {
      width: 100%; padding: 16px; border-radius: 12px;
      background: #3b82f6; color: #fff; border: none;
      font-family: 'Andika', sans-serif; font-size: 16px; font-weight: 600;
      cursor: pointer; transition: all .18s; margin-top: 4px;
      letter-spacing: .01em;
    }
    .lp-proceed-btn:hover:not(:disabled) { background: #2563eb; transform: translateY(-1px); }
    .lp-proceed-btn:disabled { opacity: .4; cursor: not-allowed; }
    .lp-proceed-btn:not(.ready) { opacity: .4; cursor: not-allowed; pointer-events: none; }
    .lp-proceed-btn.ready { opacity: 1; pointer-events: auto; }</style>
</head>
<body>
<!-- LANDING SCREEN -->
<div id="landing-screen">
  <div class="lp-wrap">

    <div class="lp-hero">
      <div class="lp-logo-wrap"><img src="data:image/png;base64," alt="DVS Health" class="lp-logo"></div>
      <div class="lp-eyebrow">Diversity Health Solutions</div>
      <div class="lp-title">Health Insurance Application</div>
      <div class="lp-sub">Licensed Insurance Broker &nbsp;&middot;&nbsp; ACA &amp; Private Coverage</div>
    </div>

    <div class="lp-card">
      <div class="lp-section-label">Please select how you are accessing this form</div>

      <div class="lp-options">

        <button type="button" class="lp-option" id="opt-self" onclick="selectLandingOption('self')">
          <div class="lp-option-icon-wrap">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <div class="lp-option-body">
            <div class="lp-opt-title">Individual Enrollment</div>
            <div class="lp-opt-desc">Apply for health insurance coverage for yourself or your family.</div>
          </div>
        </button>

        <button type="button" class="lp-option" id="opt-partner" onclick="selectLandingOption('partner')">
          <div class="lp-option-icon-wrap">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" xmlns="http://www.w3.org/2000/svg">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <div class="lp-option-body">
            <div class="lp-opt-title">Referral Partners</div>
            <div class="lp-opt-desc">Refer a client for health insurance enrollment and plan options.</div>
          </div>
        </button>

        <button type="button" class="lp-option" id="opt-broker" onclick="selectLandingOption('broker')">
          <div class="lp-option-icon-wrap">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <div class="lp-option-body">
            <div class="lp-opt-title">Broker Access — Jay Northcutt</div>
            <div class="lp-opt-desc">Licensed broker completing an application on behalf of a client.</div>
          </div>
        </button>

      </div>

      <div class="lp-input-wrap" id="partner-name-input-wrap">
        <input type="text" id="partner-name-field" placeholder="Your full name" class="lp-input">
      </div>
      <div class="broker-password-input" id="broker-password-wrap">
        <input type="password" id="broker-password-field" placeholder="Broker password" class="lp-input" oninput="checkBrokerReady()">
      </div>

      <button type="button" class="lp-proceed-btn" id="landing-continue-btn" onclick="startForm()" id="landing-continue-btn">
        Start Application
      </button>
        <input type="hidden" id="broker-password-error">
      <input type="hidden" id="landing-partner-name">
      <span class="lp-footer-item">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Encrypted
        </span>
        <span class="lp-footer-item">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Secure
        </span>
        <span class="lp-footer-item">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Confidential
        </span>
      </div>

    </div>
  </div>
</div>
<!-- APP TYPE SELECTION SCREEN -->
<div id="apptype-screen" style="display:none; min-height:100vh; align-items:center; justify-content:center; padding:2rem 1rem; background:#0d1525; flex-direction:column;">
  <div class="at-wrap">
    <div class="at-hero">
      <div class="at-logo-wrap">
        <img src="data:image/png;base64," alt="DVS Health" class="at-logo">
      </div>
      <div class="at-eyebrow">Diversity Health Solutions</div>
      <div class="at-title">Select Application Type</div>
      <div class="at-sub" id="at-sub-text">Please select the type of health coverage you are applying for.</div>
    </div>
    <div class="at-card">
      <button type="button" class="at-back-btn" onclick="goBackFromAppType()">&#8592; Return to selection</button>
      <div class="at-section-label">Which application would you like to complete?</div>
      <div class="at-options">
        <button type="button" class="at-option" id="at-opt-aca" onclick="selectAppType('aca')">
          <div class="at-icon aca">
            <svg viewBox="0 0 24 24" fill="none" stroke="#4a8ac4" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <div>
            <div class="at-opt-title">ACA / Marketplace Form</div>
            <div class="at-opt-desc">Subsidized coverage through the federal or state marketplace. Income-based eligibility required.</div>
          </div>
          <div class="at-radio"></div>
        </button>
        <button type="button" class="at-option" id="at-opt-private" onclick="selectAppType('private')">
          <div class="at-icon private">
            <svg viewBox="0 0 24 24" fill="none" stroke="#9a7ac4" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div>
            <div class="at-opt-title">Private / Group Form</div>
            <div class="at-opt-desc">Non-marketplace coverage including underwritten major medical, group, and supplemental plans.</div>
          </div>
          <div class="at-radio"></div>
        </button>
      </div>
      <div class="at-divider"></div>
      <button type="button" class="at-btn" id="at-continue-btn" onclick="proceedToForm()">Continue to Application</button>
      <div class="at-footer">
        <span class="at-footer-item">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Encrypted
        </span>
        <span class="at-footer-item">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Secure
        </span>
        <span class="at-footer-item">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Confidential
        </span>
      </div>
    </div>
  </div>
</div>

<div class="parallax-bg" style="position:fixed;top:0;left:0;right:0;bottom:0;background-image:url('data:image/png;base64,');background-repeat:no-repeat;background-position:center center;background-size:55%;opacity:0.05;z-index:0;pointer-events:none;will-change:transform;"></div>
<div class="wrap" style="display:none;">
  <button type="button" class="back-btn" id="back-to-landing" onclick="goBackToLanding()">&#8592; Back</button>
  <div class="header">
    <img src="data:image/png;base64," alt="DVS Health" style="height: 90px; width: auto; margin-bottom: 1rem; display: block;">
    <h1>Health Insurance Application</h1>
    <p>Please complete all required fields. Your submission is sent securely to your DVS agent.</p>
  </div>

  <form id="aca-form">

    <!-- For Referral Partners / Self-Service / Agent Section -->

    <!-- REFERRAL PARTNER view -->
    <div class="section" id="section-referral-partner">
      <div class="section-title">Referral partner information</div>
      <div class="field-row">
        <div class="field">
          <label>Partner / Organization name</label>
          <input type="text" name="partner_name" placeholder="Organization or company name (if applicable)">
        </div>
        <div class="field">
          <label>Your name <span class="req">*</span></label>
          <input type="text" name="partner_contact" id="partner-contact-input" placeholder="Full legal name">
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Your email <span class="req">*</span></label>
          <input type="email" name="partner_email" id="partner-email-input" placeholder="Professional email address">
        </div>
        <div class="field">
          <label>Your phone <span class="req">*</span></label>
          <input type="tel" name="partner_phone" id="partner-phone-input" placeholder="(000) 000-0000">
        </div>
      </div>
    </div>

    <!-- SELF-SERVICE CLIENT view -->
