      if (effSel) {
        effSel.innerHTML = '<option value="">Select effective date</option>';
        var months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
        var now = new Date();
        // Next 12 months, any day 1-28 + last day
        for (var m = 1; m <= 12; m++) {
          var d = new Date(now.getFullYear(), now.getMonth() + m, 1);
          var monthName = months[d.getMonth()];
          var year = d.getFullYear();
          // Add 1st through 28th plus last day
          for (var day = 1; day <= 28; day++) {
            var suffix = day === 1 ? 'st' : day === 2 ? 'nd' : day === 3 ? 'rd' : 'th';
            var opt = document.createElement('option');
            opt.value = monthName + ' ' + day + ', ' + year;
            opt.textContent = monthName + ' ' + day + suffix + ', ' + year;
