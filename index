  function getBookOfBusiness(carrier) {
    if (!carrier) return '';
    // Check exact match first
    if (BOOK_OF_BUSINESS_MAP[carrier]) return BOOK_OF_BUSINESS_MAP[carrier];
    // Check partial match (case-insensitive)
    var lower = carrier.toLowerCase();
    for (var key in BOOK_OF_BUSINESS_MAP) {
      if (lower.includes(key.toLowerCase()) || key.toLowerCase().includes(lower)) {
        return BOOK_OF_BUSINESS_MAP[key];
      }
    }
    return '';
  }

