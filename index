  window.addEventListener('DOMContentLoaded', function() {
    buildEffectiveDates();

    // Wire up all dropdowns safely after DOM is ready
    var adultsEl = document.getElementById('adults-applying-select');
    var depsEl = document.getElementById('deps-applying-select');
    var householdEl = document.getElementById('household-size-select');
    var employmentEl = document.getElementById('employment-select');
    var carrierEl = document.querySelector('[name="carrier"]');

    // Attach both 'change' and 'input' for mobile compatibility
    function on(el, fn) {
      if (!el) return;
      el.addEventListener('change', fn);
      el.addEventListener('input', fn);
    }

    on(adultsEl, handleApplyingChange);
    on(depsEl, handleApplyingChange);
    on(householdEl, handleHouseholdChange);
    on(employmentEl, function() { handleEmployment(this.value); });
    on(carrierEl, function() { handleCarrierChange(this.value); });

    // Card number formatting
    var cardNum = document.getElementById('card-num-input');
    if (cardNum) cardNum.addEventListener('input', function() {
      var v = this.value.replace(/\D/g, '').substring(0, 16);
      v = v.replace(/(.{4})/g, '$1 ').trim();
      this.value = v;
    });

    // Card expiry formatting
    var cardExp = document.getElementById('card-exp-input');
    if (cardExp) cardExp.addEventListener('input', function() {
      var v = this.value.replace(/\D/g, '').substring(0, 4);
      if (v.length > 2) v = v.slice(0,2) + '/' + v.slice(2);
      this.value = v;
    });

    // SSN auto-format
    var ssnInput = document.getElementById('ssn-input');
    if (ssnInput) ssnInput.addEventListener('input', function() {
      var v = this.value.replace(/\D/g, '').substring(0, 9);
      if (v.length > 5) v = v.slice(0,3) + '-' + v.slice(3,5) + '-' + v.slice(5);
      else if (v.length > 3) v = v.slice(0,3) + '-' + v.slice(3);
      this.value = v;
    });

    // Signature date — always today
    var sigDate = document.getElementById('sig-date');
    if (sigDate) {
      var today = new Date();
      var yyyy = today.getFullYear();
      var mm = String(today.getMonth() + 1).padStart(2, '0');
      var dd = String(today.getDate()).padStart(2, '0');
      sigDate.value = yyyy + '-' + mm + '-' + dd;
    }

    // Dependent DOB — check for newborn SEP
    document.addEventListener('change', function(e) {
      if (e.target && e.target.name && e.target.name.includes('_dob') && e.target.name.includes('dep')) {
        buildEffectiveDates(e.target.value);
      }
    });

    // Format all DOB fields as MM/DD/YYYY on change
    function formatDOB(input) {
      var val = input.value; // comes as YYYY-MM-DD from date input
      if (!val) return;
      var parts = val.split('-');
      if (parts.length === 3) {
        input.dataset.formatted = parts[1] + '/' + parts[2] + '/' + parts[0];
      }
    }

    // Override FormData collection to use formatted DOB values
    document.addEventListener('change', function(e) {
      if (e.target && e.target.type === 'date') {
        formatDOB(e.target);
      }
    });

    // Build initial income cards
    rebuildIncomeCards();

    // Make sure carrier tabs are visible and working on form load
    // Reset to All tab active state
    var tabs = document.querySelectorAll('#carrier-filter-tabs .carrier-filter-tab');
