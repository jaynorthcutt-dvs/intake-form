  function buildEffectiveDates(depDob) {
    const sel = document.getElementById('effective-date-select');
    if (!sel) return;
    const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const now = new Date();
    const currentVal = sel.value;

    // Clear existing options except placeholder
    while (sel.options.length > 1) sel.remove(1);

    // Check if a dependent was born within the last 60 days
    let allowPrior = false;
    if (depDob) {
      const dob = new Date(depDob);
      const diffDays = (now - dob) / (1000 * 60 * 60 * 24);
      if (diffDays >= 0 && diffDays <= 60) allowPrior = true;
    }

    // If prior birth qualifies, add the 1st of the current month and possibly last month
    if (allowPrior) {
      const dob = new Date(depDob);
      const birthMonth1st = new Date(dob.getFullYear(), dob.getMonth(), 1);
      // Add from birth month forward to be safe
      const startMonth = birthMonth1st < now ? birthMonth1st : now;
      // Add current month 1st if not already passed more than 60 days
      const thisMonth = new Date(now.getFullYear(), now.getMonth(), 1);
      if ((now - thisMonth) / (1000*60*60*24) <= 60) {
        const val = months[thisMonth.getMonth()] + ' 1, ' + thisMonth.getFullYear();
        const opt = document.createElement('option');
        opt.value = val;
        opt.textContent = val + ' ★ (Qualifying birth event)';
        opt.style.color = '#93c5fd';
        sel.appendChild(opt);
      }
    }

    // Always add next 12 months
    for (let i = 1; i <= 12; i++) {
      const d = new Date(now.getFullYear(), now.getMonth() + i, 1);
      const value = months[d.getMonth()] + ' 1, ' + d.getFullYear();
      const opt = document.createElement('option');
      opt.value = value;
      opt.textContent = value;
      sel.appendChild(opt);
    }

    // Restore previous selection if still valid
    if (currentVal) {
      for (let i = 0; i < sel.options.length; i++) {
        if (sel.options[i].value === currentVal) { sel.value = currentVal; break; }
      }
    }
  }



