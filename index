  function getSavedPartners() {
    try {
      return JSON.parse(localStorage.getItem('dvs_saved_partners') || '[]');
    } catch(e) { return []; }
  }

  function savePartner(name) {
    if (!name || name === 'Self-Service') return;
    try {
      var partners = getSavedPartners();
      // Remove duplicates (case-insensitive), then add to front
      partners = partners.filter(function(p) { return p.toLowerCase() !== name.toLowerCase(); });
      partners.unshift(name);
      // Keep max 10
      partners = partners.slice(0, 10);
      localStorage.setItem('dvs_saved_partners', JSON.stringify(partners));
    } catch(e) {}
  }

  function removePartner(name) {
    try {
      var partners = getSavedPartners().filter(function(p) { return p !== name; });
      localStorage.setItem('dvs_saved_partners', JSON.stringify(partners));
      renderSavedPartners();
    } catch(e) {}
  }

  function renderSavedPartners(filter) {
    var partners = getSavedPartners();
    if (filter) partners = partners.filter(function(p) { return p.toLowerCase().includes(filter.toLowerCase()); });
    var list = document.getElementById('saved-partners-list');
    var chips = document.getElementById('saved-partner-chips');
    if (!list || !chips) return;
    if (partners.length === 0) { list.style.display = 'none'; return; }
    list.style.display = 'block';
    chips.innerHTML = partners.map(function(p) {
      var safe = encodeURIComponent(p);
      return '<div class="saved-partner-chip" onclick="selectSavedPartner(decodeURIComponent(\'' + safe + '\'))">' + '<span>' + p + '</span>' + '<button class="chip-remove" type="button" onclick="event.stopPropagation();removePartner(decodeURIComponent(\'' + safe + '\'))" title="Remove">&times;</button>' + '</div>';
    }).join('');
  }

