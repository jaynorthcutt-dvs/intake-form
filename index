  function populateAddEffectiveDates(selId) {
    var sel = document.getElementById(selId);
    if (!sel) return;
    var isPrivate = document.body.dataset.appType === 'private';
    var months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    var now = new Date();
    sel.innerHTML = '<option value="">Select effective date</option>';
    if (isPrivate) {
      for (var m = 1; m <= 12; m++) {
        var d = new Date(now.getFullYear(), now.getMonth() + m, 1);
        for (var day = 1; day <= 28; day++) {
          var suffix = day===1?'st':day===2?'nd':day===3?'rd':'th';
          var opt = document.createElement('option');
          opt.value = months[d.getMonth()] + ' ' + day + ', ' + d.getFullYear();
          opt.textContent = months[d.getMonth()] + ' ' + day + suffix + ', ' + d.getFullYear();
          sel.appendChild(opt);
        }
      }
    } else {
      for (var i = 1; i <= 12; i++) {
        var d2 = new Date(now.getFullYear(), now.getMonth() + i, 1);
        var val2 = months[d2.getMonth()] + ' 1, ' + d2.getFullYear();
        var opt2 = document.createElement('option');
        opt2.value = val2; opt2.textContent = val2;
        sel.appendChild(opt2);
      }
    }
  }




